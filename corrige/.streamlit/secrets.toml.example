# Modèle de configuration des secrets (à copier en secrets.toml et compléter).
# Le vrai fichier secrets.toml ne doit JAMAIS être versionné.
[mysql]
host = "localhost"
port = 3306
user = "VOTRE_UTILISATEUR"
password = "VOTRE_MOT_DE_PASSE"
database = "fco_db"

# Authentification de l'application (facultatif).
# Sans cette section, l'app utilise les comptes de démonstration
# (admin / labo / eleveur, mot de passe : fco2026).
# rôles disponibles : admin (tout) · laboratoire · eleveur
[auth.admin]
name = "Administrateur"
role = "admin"
password = "VOTRE_MOT_DE_PASSE"        # en clair (fichier non versionné)

[auth.laborantin]
name = "Jean Dupont"
role = "laboratoire"
password = "VOTRE_MOT_DE_PASSE"

# Paiement des abonnements via Stripe Payment Links (facultatif).
# Ce sont de simples URL publiques https://buy.stripe.com/... : AUCUNE clé
# secrète Stripe ne doit figurer ici ni dans le dépôt.
# Pour les créer : Dashboard Stripe -> Produits -> Payment Links -> créer un
# lien pour un abonnement annuel (120 €/an "Éleveur", 600 €/an "Laboratoire"),
# puis copier l'URL générée ci-dessous. Sans cette section, les boutons
# "S'abonner" s'affichent désactivés (mode démonstration).
[stripe]
eleveur = "https://buy.stripe.com/VOTRE_LIEN_ELEVEUR"
laboratoire = "https://buy.stripe.com/VOTRE_LIEN_LABORATOIRE"
